# Add additional ssh configurations to ~/.ssh/config.d/
# https://superuser.com/questions/247564/is-there-a-way-for-one-ssh-config-file-to-include-another-one
Include config.d/*

Host github.com
  IdentityFile ~/.ssh/id_ed25519

Host *
  AddKeysToAgent yes
  UseKeychain yes
  # Only offer IdentityFiles configured for this host, instead of every key in
  # the agent (avoids "too many auth failures" lockouts on multi-key setups).
  IdentitiesOnly yes
  # Keep long-running ssh sessions alive across NAT/firewall idle timeouts.
  ServerAliveInterval 60
  ServerAliveCountMax 5
