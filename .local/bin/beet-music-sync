#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.14"
# dependencies = ["beets"]
# ///
"""Sync beets metadata to Music.app for tracks matching a beets query.

Usage:
    beet-music-sync [beets query...]

Examples:
    beet-music-sync                    # sync everything
    beet-music-sync albumartist:C418
    beet-music-sync album:TUNIC
"""

import itertools
import subprocess
import sys

from beets import config
from beets.library import Item, Library, parse_query_parts


def esc(s):
    return str(s or "").replace("\\", "\\\\").replace('"', '\\"')


def sync_to_music(tracks):
    by_album = {}
    for item in tracks:
        if item.album:
            by_album.setdefault((item.album, item.albumartist or ""), []).append(item)

    total_updated = total_not_found = 0

    for (album, albumartist), album_tracks in sorted(by_album.items()):
        label = f"{albumartist} - {album}" if albumartist else album
        album_updated = album_not_found = 0

        # Process in batches of 50 to avoid AppleScript size limits
        for batch in itertools.batched(album_tracks, 50):
            lines = [
                'tell application "Music"',
                "    set lib to library playlist 1",
                "    set updated to 0",
            ]
            for item in batch:
                discnum = int(item.disc or 0)
                title_esc = esc(item.title)
                # Match by title+album — avoids per-disc vs absolute track number mismatch
                lines.append(
                    f'    set matchTracks to (every file track of lib whose album is "{esc(album)}" and name is "{title_esc}")'
                )
                lines.append("    repeat with aTrack in matchTracks")
                lines.extend([
                    f'        set name of aTrack to "{title_esc}"',
                    f'        set artist of aTrack to "{esc(item.artist)}"',
                    f'        set album artist of aTrack to "{esc(albumartist)}"',
                    f'        set album of aTrack to "{esc(album)}"',
                ])
                if item.year:
                    lines.append(f"        set year of aTrack to {int(item.year)}")
                if genre := item.get("genre"):
                    lines.append(f'        set genre of aTrack to "{esc(genre)}"')
                if composer := item.get("composer"):
                    lines.append(f'        set composer of aTrack to "{esc(composer)}"')
                if discnum:
                    lines.append(f"        set disc number of aTrack to {discnum}")
                lines.extend(["        set updated to updated + 1", "    end repeat"])
            lines.extend(["    return updated", "end tell"])

            result = subprocess.run(
                ["osascript", "-e", "\n".join(lines)], capture_output=True, text=True
            )
            if result.returncode != 0:
                print(f"  ERROR '{label}': {result.stderr.strip()}", file=sys.stderr)
                album_not_found += len(batch)
            else:
                out = result.stdout.strip()
                batch_updated = int(out) if out.isdigit() else 0
                album_updated += batch_updated
                album_not_found += max(0, len(batch) - batch_updated)

        total_updated += album_updated
        total_not_found += album_not_found
        status = f"{album_updated} updated" + (
            f", {album_not_found} not in Music.app" if album_not_found else ""
        )
        print(f"  {label}: {status}")

    print(
        f"\n{total_updated} track(s) synced, {total_not_found} not found in Music.app."
    )


if __name__ == "__main__":
    config.read()
    lib = Library(config["library"].as_filename())
    query, sort = parse_query_parts(sys.argv[1:], Item)
    tracks = list(lib.items(query, sort))
    print(f"Found {len(tracks)} track(s). Syncing to Music.app...")
    sync_to_music(tracks)
