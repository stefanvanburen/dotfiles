# Fix the syntax highlighting for these files in the GitHub UI.
# https://github.com/github-linguist/linguist/blob/main/docs/overrides.md#using-gitattributes
# https://github.com/github-linguist/linguist/blob/main/lib/linguist/languages.yml
/.config/git/config linguist-language=gitconfig
/.config/git/message linguist-language=commit
/.config/git/ignore linguist-language=gitignore
/.ssh/config linguist-language=SSH-Config
