#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.12"
# dependencies = ["beets"]
# ///
"""Sync beets metadata to Music.app for tracks matching a beets query.

Usage:
    beet-music-sync [beets query...]

Examples:
    beet-music-sync                    # sync everything
    beet-music-sync albumartist:C418
    beet-music-sync album:TUNIC
"""

import subprocess
import sys

from beets import config
from beets.library import Item, Library, parse_query_parts


def esc(s):
    return str(s or "").replace("\\", "\\\\").replace('"', '\\"')


def sync_to_music(tracks):
    by_album = {}
    for item in tracks:
        if item.album:
            by_album.setdefault((item.album, item.albumartist or ""), []).append(item)

    total_updated = total_not_found = 0

    for (album, albumartist), album_tracks in sorted(by_album.items()):
        lines = ['tell application "Music"', "    set lib to library playlist 1", "    set updated to 0"]
        for item in album_tracks:
            tracknum = int(item.track or 0)
            discnum = int(item.disc or 0)
            # OR on album artist catches tracks not yet synced (empty in Music.app)
            lines.append(f'    set matchTracks to (every file track of lib whose album is "{esc(album)}" and track number is {tracknum} and (album artist is "{esc(albumartist)}" or album artist is ""))')
            lines.append("    repeat with aTrack in matchTracks")
            lines += [
                f'        set name of aTrack to "{esc(item.title)}"',
                f'        set artist of aTrack to "{esc(item.artist)}"',
                f'        set album artist of aTrack to "{esc(albumartist)}"',
                f'        set album of aTrack to "{esc(album)}"',
            ]
            if item.year:
                lines.append(f"        set year of aTrack to {int(item.year)}")
            if genre := item.get("genre"):
                lines.append(f'        set genre of aTrack to "{esc(genre)}"')
            if composer := item.get("composer"):
                lines.append(f'        set composer of aTrack to "{esc(composer)}"')
            if discnum:
                lines.append(f"        set disc number of aTrack to {discnum}")
            lines += ["        set updated to updated + 1", "    end repeat"]
        lines += ["    return updated", "end tell"]

        result = subprocess.run(["osascript", "-e", "\n".join(lines)], capture_output=True, text=True)
        label = f"{albumartist} - {album}" if albumartist else album
        if result.returncode != 0:
            print(f"  ERROR '{label}': {result.stderr.strip()}", file=sys.stderr)
            total_not_found += len(album_tracks)
        else:
            updated = int(result.stdout.strip()) if result.stdout.strip().isdigit() else 0
            not_found = max(0, len(album_tracks) - updated)
            total_updated += updated
            total_not_found += not_found
            status = f"{updated} updated" + (f", {not_found} not in Music.app" if not_found else "")
            print(f"  {label}: {status}")

    print(f"\n{total_updated} track(s) synced, {total_not_found} not found in Music.app.")


config.read()
lib = Library(config["library"].as_filename())
query_args = sys.argv[1:]
query, sort = parse_query_parts(query_args, Item) if query_args else (None, None)
tracks = list(lib.items(query, sort) if query else lib.items())
print(f"Found {len(tracks)} track(s). Syncing to Music.app...")
sync_to_music(tracks)
