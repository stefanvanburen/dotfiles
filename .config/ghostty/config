# https://ghostty.org/docs/config

# https://ghostty.org/docs/config/reference#theme
theme = light:Modus Operandi,dark:Modus Vivendi

# typically configuring fonts - check ./config.fonts
# https://ghostty.org/docs/config/reference#config-file
config-file = ?config.local

# https://ghostty.org/docs/config/reference#cursor-color
cursor-color = #EE483E
# https://ghostty.org/docs/config/reference#adjust-cursor-thickness
# Make the cursor thicker.
adjust-cursor-thickness = 3

# default: 10000000 bytes; bumped by an order of magnitude
# ref: `ghostty +show-config --default | rg scrollback-limit`
scrollback-limit = 100000000

# Hide the mouse cursor while typing; reappears on movement.
mouse-hide-while-typing = true

# Make ⌥ behave like Alt for TUI apps (nvim, fish key bindings, etc.).
macos-option-as-alt = true

# https://ghostty.org/docs/config/keybind

keybind = ctrl+f>h=goto_split:left
keybind = ctrl+f>j=goto_split:bottom
keybind = ctrl+f>k=goto_split:top
keybind = ctrl+f>l=goto_split:right

keybind = ctrl+f>v=new_split:right
keybind = ctrl+f>s=new_split:down

# https://ghostty.org/docs/config/keybind/reference#toggle_split_zoom
keybind = ctrl+f>z=toggle_split_zoom

# https://ghostty.org/docs/config/keybind/reference#write_scrollback_file
keybind = ctrl+f>p=write_scrollback_file:paste
